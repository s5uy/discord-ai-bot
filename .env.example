DISCORD_TOKEN=
OPENAI_API_KEY=

# Optional: omit to use OpenAI’s default. If you set a host only (e.g. https://api.openai.com), /v1 is added for you.
# OPENAI_BASE_URL=https://api.openai.com/v1

OPENAI_MODEL=gpt-4o-mini

# Kiro / AWStore (https://api.kiro.cheap): use their API key (sk-aw-...) and a Claude model id, e.g.
# OPENAI_BASE_URL=https://api.kiro.cheap/v1
# OPENAI_MODEL=claude-sonnet-4.5

# Optional: shown in /about
BOT_OWNER=

# Optional: sync slash commands to one guild only (faster while testing; omit for global sync)
# DISCORD_GUILD_ID=123456789012345678

# Optional: logging (default INFO)
# LOG_LEVEL=INFO

# Optional: one line, keep short for Discord limits
SYSTEM_PROMPT=You are a concise, helpful assistant in a Discord server. Be warm and clear.
